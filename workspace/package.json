{
  "name": "qq-bot-platform",
  "version": "1.0.0",
  "description": "QQ机器人平台 - 基于QQ开放平台官方API的本地运行机器人",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "build:web": "cd web && npm run build",
    "build:all": "npm run build && npm run build:web",
    "setup": "npm install && cd web && npm install",
    "serve": "npm run build:all && npm start",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "better-sqlite3": "^11.0.0",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.0",
    "qq-guild-bot": "^2.9.5",
    "tweetnacl": "^1.0.3",
    "uuid": "^9.0.0",
    "winston": "^3.11.0",
    "winston-daily-rotate-file": "^4.7.0",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/multer": "^2.2.0",
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.0",
    "adm-zip": "^0.6.0",
    "multer": "^2.2.0",
    "nodemon": "^3.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
